#! /usr/bin/env bash
# Author:
#   Aaron Kuehler
#
# Purpose:
#   Uninstall the dotfiles
#

set -euo pipefail

DOTFILES_HOME="$HOME/.files"

function remove_configuration() {
    pushd "$DOTFILES_HOME" || { echo "Failed to change working directory to '$DOTFILES_HOME'. Aborting"; exit 1; }
    stow --delete \
        asdf \
        bash \
        btop \
        emacs \
        firefox \
        ghostty \
        git \
        gnome-terminal \
        iterm2 \
        k9s \
        proselint \
        ripgrep \
        ruby \
        scripts \
        ssh
    popd || return
}

remove_configuration


exit 0
